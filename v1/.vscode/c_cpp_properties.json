{
  "configurations": [
    {
      "name": "openEuler-DPDK",
      "compilerPath": "/usr/bin/cc",
      "cStandard": "gnu11",
      "intelliSenseMode": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}",
        "/usr/include/dpdk",
        "/usr/include/libnl3"
      ],
      "forcedInclude": [
        "/usr/include/dpdk/rte_config.h"
      ],
      "compilerArgs": [
        "-march=corei7",
        "-mrtm"
      ],
      "compileCommands": "${workspaceFolder}/compile_commands.json"
    }
  ],
  "version": 4
}
